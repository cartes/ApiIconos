{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS"
    },
    "deploy": {
        "releaseCommand": "php artisan optimize:clear && php artisan migrate --force && php artisan config:cache && php artisan route:cache",
        "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
        "restartPolicyType": "ON_FAILURE",
        "healthcheckPath": "/up",
        "healthcheckTimeout": 120
    }
}
